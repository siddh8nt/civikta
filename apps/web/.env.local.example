# Copy to .env.local and fill in values.
# Without these, the app runs in stub/fallback mode:
#   - GPS button still works  (no Maps key needed)
#   - Location search disabled  (needs Maps + Places APIs)
#   - Map view shows issue list  (no map tiles)

# Backend URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Google Maps JavaScript API key
# Enable in Google Cloud Console: Maps JavaScript API + Places API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Firebase web config (for Firebase Auth and Storage — future wiring)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
