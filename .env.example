# Root reference of every env flag CIVIKTA understands.
# Backend reads these from services/api/.env ; frontend from apps/web/.env.local
# Everything has a safe default — leave a value blank to use the offline default.

# ---- Backend seam selectors (see README) ----
CIVIKTA_PIPELINE=deterministic   # deterministic | agentic
CIVIKTA_LLM=stub                 # stub | gemini
CIVIKTA_REPO=memory              # memory | supabase
CIVIKTA_AUTH=stub                # stub | firebase

# ---- Gemini / Google AI Studio (only when CIVIKTA_LLM=gemini) ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
VERTEX_EMBEDDING_MODEL=text-embedding-004

# ---- Supabase (only when CIVIKTA_REPO=supabase) ----
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ---- Firebase (only when CIVIKTA_AUTH=firebase) ----
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=   # path to service account json

# ---- Frontend (apps/web/.env.local) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
