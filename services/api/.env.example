# CIVIKTA backend config. Copy to .env. Everything has a working default.

# Seam selectors
CIVIKTA_PIPELINE=deterministic   # deterministic | agentic
CIVIKTA_LLM=stub                 # stub | gemini
CIVIKTA_REPO=memory              # memory | supabase
CIVIKTA_AUTH=stub                # stub | firebase

# CORS (frontend origin)
CIVIKTA_CORS_ORIGINS=http://localhost:3000

# Gemini / Google AI Studio (CIVIKTA_LLM=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
VERTEX_EMBEDDING_MODEL=text-embedding-004

# Supabase (CIVIKTA_REPO=supabase)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Firebase (CIVIKTA_AUTH=firebase)
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
